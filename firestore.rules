rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Identity helpers
    function isOwner(data) { return isSignedIn() && data.uid == request.auth.uid; }
    
    // RBAC: We use a get() for writes, but keep reads more open for performance
    // In a production app, we might use custom claims for role-based list access.
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getRole() == 'Admin';
    }

    function isValidUser(data) {
      return data.uid is string && 
             data.name is string && data.name.size() > 0 &&
             data.role in ['Admin', 'Doctor', 'Nurse', 'Staff'] &&
             data.employeeId is string &&
             data.createdAt is string;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && (userId == request.auth.uid || isAdmin()) && isValidUser(incoming());
      allow update: if isSignedIn() && (
        isAdmin() || 
        (userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['name']) && isValidUser(incoming()))
      );
      allow delete: if isAdmin();
    }

    // --- Patients ---
    match /patients/{patientId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // --- Visits ---
    match /visits/{visitId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // --- Connection Test ---
    match /test/connection {
      allow get: if true;
    }
  }
}
